3. ingestion.py (Ingestion & RAG Knowledge Base)
PythonCopyimport os
from langchain.document_loaders import UnstructuredExcelLoader, PyMuPDFLoader
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain.embeddings import HuggingFaceEmbeddings
from langchain.vectorstores import FAISS
from llama_index.core import Document
from llama_index.retrievers.bm25 import BM25Retriever
from config import config

class IngestionPipeline:
    def __init__(self):
        self.embeddings = HuggingFaceEmbeddings(model_name=config.EMBEDDING_MODEL)
        self.splitter = RecursiveCharacterTextSplitter(chunk_size=config.CHUNK_SIZE, chunk_overlap=config.CHUNK_OVERLAP)
        self.vectorstore = None
        self.bm25_retriever = None
    
    def ingest_vdr(self, path: str):
        """Ingest all files in VDR path."""
        docs = []
        for file in os.listdir(path):
            if file.endswith('.xlsx'):
                loader = UnstructuredExcelLoader(os.path.join(path, file))
                docs.extend(loader.load())
            elif file.endswith('.pdf'):
                loader = PyMuPDFLoader(os.path.join(path, file))
                docs.extend(loader.load())
        
        # Chunk
        chunks = self.splitter.split_documents(docs)
        
        # Vector index
        self.vectorstore = FAISS.from_documents(chunks, self.embeddings)
        
        # BM25 for keyword
        bm25_docs = [Document(text=chunk.page_content) for chunk in chunks]
        self.bm25_retriever = BM25Retriever.from_defaults(nodes=bm25_docs)
        
        return len(chunks)  # Return num chunks ingested
    
    def query_rag(self, query: str):
        """Hybrid retrieval."""
        vector_results = self.vectorstore.similarity_search(query, k=config.TOP_K)
        bm25_results = self.bm25_retriever.retrieve(query)
        # Merge unique (simple dedup by content)
        combined = list(set(vector_results + bm25_results))
        return [doc.page_content for doc in combined[:config.TOP_K]]
