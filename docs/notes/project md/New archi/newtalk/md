            ax2.axvline(np.mean(paths_fit[:, -1]), color='darkred', lw=2.5, linestyle='--',
                        label=f'Mean sim final ({np.mean(paths_fit[:, -1]):.1f}{unit})')
        
        ax2.axvline(y_real[-1], color='black', lw=2.5, linestyle='-', 
                    label=f'Real final ({y_real[-1]:.1f}{unit})')
        ax2.set_xlabel(f'Final Synergy Value ({unit})')
        ax2.set_ylabel('Density')
        ax2.grid(alpha=0.3, linestyle='--')
        ax2.legend(loc='upper right', fontsize=9)
        
        plt.tight_layout()
        pdf.savefig(fig)
