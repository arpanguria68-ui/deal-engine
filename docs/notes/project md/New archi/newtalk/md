The code implements exact maximum likelihood estimation (MLE) using the closed-form conditional transition density of the Vasicek (OU) process — this is the standard and most statistically efficient method used in practice.
PythonCopyimport numpy as np
import pandas as pd
from scipy.optimize import minimize
import matplotlib.pyplot as plt

def vasicek_loglik_neg(params, r, dt=1/252):
    """
    Negative log-likelihood of Vasicek model (to be minimized)
    
    Parameters
    ----------
    params : array-like [kappa, theta, sigma]
    r      : 1d numpy array of observed short rates (daily or any frequency)
    dt     : time step in years (1/252 ≈ daily, 1/12 ≈ monthly, 1 ≈ annual)
    
    Returns
    -------
    negative log-likelihood value
    """
    kappa, theta, sigma = params
    
    # Prevent invalid parameters
    if kappa < 1e-8 or sigma < 1e-8:
        return 1e12
    
    a = np.exp(-kappa * dt)
    b = theta * (1 - a)
    c2 = (sigma**2 / (2 * kappa)) * (1 - a**2)
    
    if c2 <= 0:
        return 1e12
    
    # Residuals = observed - conditional mean
    residuals = r[1:] - (b + a * r[:-1])
    
    # Gaussian log-likelihood (up to constant)
    n = len(residuals)
    ll = -0.5 * n * np.log(2 * np.pi * c2) - 0.5 * np.sum(residuals**2 / c2)
    
    return -ll  # negative for minimization


def calibrate_vasicek_mle(
    r: np.ndarray,
    dt: float = 1/252,
    initial_guess: list = None,
    bounds: list = None,
    method: str = 'L-BFGS-B'
) -> dict:
    """
    Calibrate Vasicek model parameters via exact MLE
    
    Parameters
    ----------
    r              : array-like, observed short rates (daily recommended)
    dt             : time step in years (default: daily = 1/252)
    initial_guess  : [kappa, theta, sigma] – optional
    bounds         : list of tuples [(min_k, max_k), ...]
    method         : scipy.optimize method ('L-BFGS-B', 'Nelder-Mead', etc.)
    
    Returns
    -------
    dict with fitted parameters, log-likelihood, standard errors (approx), etc.
    """
    r = np.asarray(r)
    if len(r) < 30:
        raise ValueError("Need at least ~30 observations for reliable calibration")
    
    # Rough initial guess from OLS if not provided
    if initial_guess is None:
        dr = np.diff(r)
        r_lag = r[:-1]
        slope, intercept = np.polyfit(r_lag, dr, 1)
        kappa_ols = max(0.01, -slope / dt)
        theta_ols = intercept / slope if slope != 0 else np.mean(r)
        sigma_ols = np.std(dr - (intercept + slope * r_lag)) / np.sqrt(dt)
        initial_guess = [kappa_ols, theta_ols, sigma_ols]
    
    # Default bounds
    if bounds is None:
        bounds = [(1e-5, 10.0), (min(r)*0.5, max(r)*1.5), (1e-5, 0.1)]
    
    # Run optimization
    res = minimize(
        vasicek_loglik_neg,
        x0=initial_guess,
        args=(r, dt),
        method=method,
        bounds=bounds,
        options={'disp': False, 'maxiter': 1000}
    )
    
    if not res.success:
        print("Warning: Optimizer convergence warning → results may be unstable")
    
    kappa, theta, sigma = res.x
    loglik = -res.fun
    
    # Approximate standard errors from inverse Hessian
    try:
        hess_inv = res.hess_inv.todense()
        se = np.sqrt(np.diag(hess_inv))
    except:
        se = [np.nan, np.nan, np.nan]
    
    half_life = np.log(2) / kappa if kappa > 1e-8 else np.inf
    
    return {
        'kappa': kappa,
        'theta': theta,
        'sigma': sigma,
        'log_likelihood': loglik,
        'kappa_se': se[0],
        'theta_se': se[1],
        'sigma_se': se[2],
        'half_life_years': half_life,
        'n_observations': len(r),
        'dt_years': dt,
        'success': res.success,
        'message': res.message
    }


