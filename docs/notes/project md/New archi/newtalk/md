    context=[task_fin, task_risk]  # Selective chaining (ignores low-risk ESG if not escalated)
)

# Assemble Crew with Sequential Process (default; use Process.sequential for explicit)
crew = Crew(
    agents=[financial_agent, tech_agent, esg_agent, risk_agent, integration_agent],
    tasks=[task_fin, task_tech, task_esg, task_risk, task_int],
    process=Process.sequential,  # Enforces order
    verbose=2,  # Trace chaining
    memory=True  # Enables context propagation
)

# Run with inputs (propagates through chain)
results = crew.kickoff(inputs=deal_inputs)

# Post-run: Governance Eval (on key outputs)
contexts = ingestion.query_rag("synergy risks")  # Sample RAG for eval
for task_name, output in results.items():  # Mock; use actual task outputs
    score = gov.evaluate_faithfulness(f"Chained query for {task_name}", str(output), contexts)
    gov.log_run(f"Chained query for {task_name}", task_name, str(output), contexts)
    if gov.escalate_if_needed(score):
