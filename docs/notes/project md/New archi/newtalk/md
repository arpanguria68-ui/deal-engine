            ax1.plot(t_fit, mean_fit, lw=3.5, color='darkred',
                     label=f'Fitted OU path (κ={fitted["kappa"]:.2f}, θ={fitted["theta"]:.2f})')
            
            for path in paths_fit:
                ax1.plot(t_fit, path, lw=0.6, alpha=0.15, color='darkred')
            
            var_t = (fitted['sigma']**2 / (2 * fitted['kappa'])) * (1 - np.exp(-2 * fitted['kappa'] * t_fit))
            std_t = np.sqrt(var_t)
            ax1.fill_between(t_fit, mean_fit - std_t, mean_fit + std_t,
                             color='darkred', alpha=0.12)
            ax1.fill_between(t_fit, mean_fit - 2*std_t, mean_fit + 2*std_t,
                             color='darkred', alpha=0.05)
        
        # Formatting main plot
        unit = '%' if use_percentage else '$M'
        ax1.set_title(f'OU Synergy Fade – {deal_id}', fontsize=14)
        ax1.set_xlabel('Time (years post-close)')
