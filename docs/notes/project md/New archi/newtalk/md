# Tool 2: Monte Carlo IRR with OU Synergies (Financial)
def monte_carlo_irr(params_str):
    params = eval(params_str)  # {'entry_ebitda':50, 'price':500, 'syn_target':15}
    np.random.seed(config.SEED)
    n_sim = config.N_SIM
    irr_list = []
    for _ in range(n_sim):
        # Simple OU path for synergies (kappa=0.5, theta=0.6*syn_target, sigma=0.1)
        kappa, theta, sigma = 0.5, 0.6 * params['syn_target'], 0.1
        syn_path = [params['syn_target']]
        for t in range(1, 5):  # 5 years
            dw = np.random.normal(0, np.sqrt(0.25))  # dt=0.25 quarterly
            syn_path.append(syn_path[-1] + kappa * (theta - syn_path[-1]) * 0.25 + sigma * dw)
        # Mock FCF: ebitda * syn + terminal
        cash_flows = [-params['price']] + [params['entry_ebitda'] * s for s in syn_path] + [syn_path[-1] * 10]  # Exit multiple
        # Approx IRR (Newton)
        def npv(r): return sum(cf / (1 + r)**t for t, cf in enumerate(cash_flows))
        irr = newton(npv, 0.1) if npv(0.1) != 0 else 0
        irr_list.append(irr)
    return {'mean_irr': np.mean(irr_list), 'p_ge_18': np.mean(np.array(irr_list) >= 0.18)}

