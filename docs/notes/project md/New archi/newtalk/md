    def _create_tables(self):
        self.conn.execute("""
            CREATE TABLE IF NOT EXISTS cache (
                key TEXT PRIMARY KEY,
                value TEXT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        """)
        self.conn.commit()
    
    def fetch_fred_rates(self, symbols=['FEDFUNDS', 'ECBDFR']):
        """Fetch Fed/ECB rates."""
        key = f"fred_{'_'.join(symbols)}"
        cached = self._get_cache(key)
        if cached:
            return pd.read_json(cached)
        
        df = pdr.get_data_fred(symbols, start=config.FRED_START_DATE)
        json_str = df.to_json()
        self._set_cache(key, json_str)
        return df
    
    def fetch_tax_rates(self, region='US'):
        """Static tax CSV parse (download once)."""
        # Assume CSV downloaded to data/tax_rates.csv
        df = pd.read_csv('data/tax_rates.csv')  # Columns: year, rate, region
        return df[df['region'] == region]
    
    def fetch_loans_guidelines(self, source='SBA'):
        """Scrape SBA/EIB for loan schemes."""
        key = f"loans_{source}"
        cached = self._get_cache(key)
        if cached:
            return cached
        
        if source == 'SBA':
            url = "https://www.sba.gov/funding-programs/loans"
            response = requests.get(url)
            soup = BeautifulSoup(response.text, 'html.parser')
            guidelines = soup.find_all('div', class_='program-description')  # Adapt selector
            text = ' '.join([g.text for g in guidelines])
        else:  # EIB
            url = "https://www.eib.org/en/products/loans"
            # Similar scrape...
            text = "Mock EIB guidelines"
        
        self._set_cache(key, text)
        return text
    
    def _get_cache(self, key):
        cur = self.conn.execute("SELECT value FROM cache WHERE key=?", (key,))
        row = cur.fetchone()
        return row[0] if row else None
    
    def _set_cache(self, key, value):
        self.conn.execute("INSERT OR REPLACE INTO cache (key, value) VALUES (?, ?)", (key, value))
        self.conn.commit()
