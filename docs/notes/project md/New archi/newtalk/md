PythonCopyimport numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy import optimize

np.random.seed(42)  # for reproducibility

# ────────────────────────────────────────────────
# Core parameters (can be inputs from user / agent)
# ────────────────────────────────────────────────
entry_ebitda          = 45.0          # $M
entry_multiple        = 11.5          # base case
holding_period_years  = 5
target_irr            = 0.20          # 20% hurdle

# Distributions (mean, std dev or min/mode/max)
ebitda_growth         = {'mean': 0.085, 'std': 0.035}           # normal
margin_expansion      = {'min': -0.02, 'mode': 0.015, 'max': 0.045}  # triangular
synergy_capture_pct   = {'alpha': 4, 'beta': 3, 'max': 0.90}     # beta → skewed high
exit_multiple         = {'mean': 12.8, 'std': 2.2}               # lognormal-ish
opex_overrun_pct      = {'mean': 0.00, 'std': 0.025}             # can be negative

n_simulations = 10000

# ────────────────────────────────────────────────
# Main Monte Carlo loop
# ────────────────────────────────────────────────
irrs = np.zeros(n_simulations)

for i in range(n_simulations):
    # ─── Random draws ───
    growth_rates = np.random.normal(
        ebitda_growth['mean'],
        ebitda_growth['std'],
        holding_period_years
    )
    
    margin_changes = np.random.triangular(
        margin_expansion['min'],
        margin_expansion['mode'],
        margin_expansion['max'],
        holding_period_years
    )
    
    synergy_pct = np.random.beta(
        synergy_capture_pct['alpha'],
        synergy_capture_pct['beta']
    ) * synergy_capture_pct['max']
    
    exit_mult = np.random.normal(
        exit_multiple['mean'],
        exit_multiple['std']
    )
    exit_mult = max(6.0, exit_mult)  # floor
    
    opex_overrun = np.random.normal(
        opex_overrun_pct['mean'],
        opex_overrun_pct['std'],
        holding_period_years
    )
    
    # ─── Project EBITDA path ───
    ebitda = [entry_ebitda]
    for yr in range(holding_period_years):
        new_ebitda = ebitda[-1] * (1 + growth_rates[yr])
        new_ebitda *= (1 + margin_changes[yr])
        new_ebitda *= (1 - opex_overrun[yr])
        ebitda.append(new_ebitda)
    
    # ─── Free Cash Flow approximation (simplified) ───
    # Assume FCF ≈ 70% of EBITDA (typical rule-of-thumb after tax, capex, NWC)
    fcf_margin = 0.70
    fcf = [eb * fcf_margin for eb in ebitda[1:]]   # years 1 to n
    
    # Terminal value (exit)
    terminal_ebitda = ebitda[-1]
    terminal_value = terminal_ebitda * exit_mult
    
    # Full cash flows: outflow today, then annual FCF, last year includes exit
    cash_flows = [-entry_ebitda * entry_multiple] + fcf[:-1] + [fcf[-1] + terminal_value]
    
    # ─── Calculate IRR ───
    def npv(r):
        return sum(cf / (1 + r)**t for t, cf in enumerate(cash_flows))
    
    try:
        irr = optimize.newton(npv, 0.15)   # starting guess 15%
    except RuntimeError:
        irr = np.nan  # convergence failure
    
    irrs[i] = irr

# ────────────────────────────────────────────────
# Results & Visualization
# ────────────────────────────────────────────────
valid_irrs = irrs[~np.isnan(irrs)]
if len(valid_irrs) == 0:
    print("No valid IRR calculations")
else:
    df_stats = pd.Series(valid_irrs).describe(percentiles=[0.10, 0.25, 0.50, 0.75, 0.90])
    print("\nIRR Distribution Statistics:")
    print(df_stats.round(4))
    
    prob_success = (valid_irrs >= target_irr).mean()
    print(f"\nProbability of IRR ≥ {target_irr:.1%}: {prob_success:.1%}")
    
    # Plot
    plt.figure(figsize=(10, 6))
    plt.hist(valid_irrs, bins=60, color='#1f77b4', edgecolor='white', alpha=0.8)
    plt.axvline(target_irr, color='darkred', linestyle='--', lw=2.5, label=f'Target IRR = {target_irr:.0%}')
    plt.axvline(np.median(valid_irrs), color='gold', linestyle='-', lw=2.5, label='Median IRR')
    plt.title('Monte Carlo IRR Distribution – M&A / LBO Simulation', fontsize=14, pad=12)
    plt.xlabel('IRR', fontsize=12)
    plt.ylabel('Frequency', fontsize=12)
    plt.legend()
    plt.grid(alpha=0.3)
    plt.tight_layout()
    plt.show()
