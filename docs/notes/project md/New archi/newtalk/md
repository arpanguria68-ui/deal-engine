PythonCopyimport numpy as np
import matplotlib.pyplot as plt

def ou_path_exact(X0, theta, kappa, sigma, T, n_steps=252, n_paths=1):
    """
    Simulate exact OU paths (using conditional normal distribution)
    
    Parameters
    ----------
    X0     : float           starting value
    theta  : float           long-term mean
    kappa  : float           reversion speed
    sigma  : float           volatility
    T      : float           total time horizon
    n_steps: int             number of time steps
    n_paths: int             number of independent paths
    
    Returns
    -------
    t      : array (time points)
    paths  : (n_paths, n_steps+1) array
    """
    dt = T / n_steps
    t = np.linspace(0, T, n_steps + 1)
    
    paths = np.zeros((n_paths, n_steps + 1))
    paths[:, 0] = X0
    
    for i in range(1, n_steps + 1):
        exp_term = np.exp(-kappa * dt)
        mean = theta + (paths[:, i-1] - theta) * exp_term
        var = (sigma**2 / (2 * kappa)) * (1 - np.exp(-2 * kappa * dt))
        paths[:, i] = np.random.normal(mean, np.sqrt(var))
    
    return t, paths

def plot_ou_paths_with_confidence(
    X0, theta, kappa, sigma, T=5.0, n_steps=252, n_paths=50,
    plot_confidence=True, figsize=(11, 6)
):
    """
    Plot multiple OU paths + theoretical confidence bands
    """
    t, paths = ou_path_exact(X0, theta, kappa, sigma, T, n_steps, n_paths)
    
    # Theoretical mean path (deterministic solution)
    mean_path = theta + (X0 - theta) * np.exp(-kappa * t)
    
    # Theoretical variance at each time
    var_t = (sigma**2 / (2 * kappa)) * (1 - np.exp(-2 * kappa * t))
    
    plt.figure(figsize=figsize)
    
    # Plot individual paths (semi-transparent)
    for path in paths:
        plt.plot(t, path, lw=0.8, alpha=0.25, color='royalblue')
    
    # Plot mean path
    plt.plot(t, mean_path, lw=3.2, color='darkred', 
             label=f'Expected path (θ = {theta:.2f})')
    
    if plot_confidence:
        # ±1σ and ±2σ bands
        plt.fill_between(t, mean_path - np.sqrt(var_t), 
                         mean_path + np.sqrt(var_t), 
                         color='orange', alpha=0.18, label='±1σ band')
        plt.fill_between(t, mean_path - 2*np.sqrt(var_t), 
                         mean_path + 2*np.sqrt(var_t), 
                         color='orange', alpha=0.08, label='±2σ band')
    
    # Formatting
    plt.title(f'Ornstein–Uhlenbeck Paths\nκ = {kappa:.2f}, θ = {theta:.2f}, σ = {sigma:.2f}, {n_paths} paths')
    plt.xlabel('Time')
    plt.ylabel('X(t)')
    plt.grid(alpha=0.3, linestyle='--')
    plt.legend(loc='upper right')
    plt.tight_layout()
    plt.show()
    
    # Quick stats
    final_values = paths[:, -1]
    print(f"Final values statistics (t = {T}):")
    print(pd.Series(final_values).describe().round(2))
    print(f"Theoretical stationary mean: {theta:.2f}")
    print(f"Theoretical stationary std : {(sigma / np.sqrt(2*kappa)):.2f}")

