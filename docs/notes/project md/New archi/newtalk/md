    base_rate = 0.053
    spread = np.random.normal(interest_spread['mean'], interest_spread['std'])
    interest_rate = base_rate + spread
    
    max_lev = np.random.triangular(max_leverage['min'], max_leverage['mode'], max_leverage['max'])
    min_cov = max(1.5, np.random.normal(min_coverage['mean'], min_coverage['std']))
    
    debt_balance = initial_debt
    equity_cash_flows = []
    breach_count = 0

    for yr in range(holding_period_years):
        current_ebitda = ebitda[yr + 1]
        
        interest = debt_balance * interest_rate
        after_tax_interest = interest * (1 - tax_rate)
        tax_shield = interest * tax_rate
        
        leverage_ratio = debt_balance / current_ebitda if current_ebitda > 0 else np.inf
        coverage_ratio = current_ebitda / interest if interest > 0 else np.inf
        is_breach = (leverage_ratio > max_lev) or (coverage_ratio < min_cov)
        
        equity_cure = 0
        if is_breach:
            breach_count += 1
            interest_rate = interest_rate * (1 + breach_penalty)
            cure_amount = debt_balance * equity_cure_pct
            equity_cure = -cure_amount
            debt_balance -= cure_amount
        
