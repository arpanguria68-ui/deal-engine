def simulate_ou_path(
    initial_value: float,
    long_term_mean: float,
    kappa: float,
    sigma: float,
    steps: int,
    dt: float = 1.0
) -> np.ndarray:
    path = np.zeros(steps)
    path[0] = initial_value
    for t in range(1, steps):
        dw = np.random.normal(0, np.sqrt(dt))
        drift = kappa * (long_term_mean - path[t-1]) * dt
        diffusion = sigma * dw
        path[t] = path[t-1] + drift + diffusion
        path[t] = max(0, path[t])  # no negative synergies
    return path

