PythonCopy# comps_builder.py
# Requirements: pip install financedatabase financetoolkit yfinance pandas

import pandas as pd
from financedatabase import Equities
from financetoolkit import Toolkit
import yfinance as yf
from datetime import datetime

def build_comps_table(
    sector: str = "Technology",
    industry: str = "Software - Application",
    country: str = "United States",
    market_cap_category: str = "Large Cap",
    max_peers: int = 12,
    fmp_api_key: str = "YOUR_FREE_FMP_KEY_HERE",  # Get from financialmodelingprep.com (free tier)
    use_fmp: bool = True
) -> pd.DataFrame:
    """
    Build Comparable Companies table:
    1. Filter peers with FinanceDatabase (offline)
    2. Pull data via FinanceToolkit (FMP) or yfinance fallback
    3. Calculate key M&A multiples (EV/Revenue LTM, EV/EBITDA LTM)
    """
    # ─── Step 1: Discover peers (FinanceDatabase - offline) ───
    equities = Equities()
    peers_df = equities.select(
        sector=sector,
        industry=industry,
        country=country,
        market_cap=market_cap_category
    )
    
    if peers_df.empty:
        raise ValueError("No peers found with those filters")
    
    # Take top N by market cap (or random if you prefer)
    peers_df = peers_df.sort_values('market_cap', ascending=False).head(max_peers)
    tickers = peers_df.index.tolist()
    print(f"Selected {len(tickers)} peers: {tickers}")

    # ─── Step 2: Pull data ───
    if use_fmp and fmp_api_key.strip():
        try:
            toolkit = Toolkit(
                tickers=tickers,
                api_key=fmp_api_key,
                start_date="2023-01-01",  # adjust as needed
                quarterly=False,           # annual for LTM
                use_cached_data=True
            )
            
            # Get key metrics
            ratios = toolkit.ratios.collect_valuation_ratios(growth=False)
            enterprise_values = toolkit.get_enterprise_value()
            revenue = toolkit.income_statement.loc[:, ("Revenue", "TTM")]
            ebitda = toolkit.income_statement.loc[:, ("EBITDA", "TTM")]
            
            # Build comps table
            comps = pd.DataFrame(index=tickers)
            comps["Company Name"] = peers_df["name"]
            comps["Market Cap"]   = enterprise_values.loc[:, ("MarketCap", "Latest")]
            comps["EV"]           = enterprise_values.loc[:, ("EnterpriseValue", "Latest")]
            comps["LTM Revenue"]  = revenue
            comps["LTM EBITDA"]   = ebitda
            comps["EV/Revenue"]   = comps["EV"] / comps["LTM Revenue"]
            comps["EV/EBITDA"]    = comps["EV"] / comps["LTM EBITDA"]
            
            # Add sector/industry from FinanceDatabase
            comps["Sector"]   = peers_df["sector"]
            comps["Industry"] = peers_df["industry"]
            
            return comps.round(2)
        
        except Exception as e:
            print(f"FMP failed ({e}) → falling back to yfinance")
    
    # ─── Fallback: yfinance (only prices + basic info) ───
    print("Using yfinance fallback (limited multiples)")
    data = {}
    for ticker in tickers:
        try:
            stock = yf.Ticker(ticker)
            info = stock.info
            data[ticker] = {
                "Company Name": info.get("longName", ticker),
                "Market Cap": info.get("marketCap", None),
                "EV": info.get("enterpriseValue", None),  # sometimes available
                "Sector": info.get("sector", "N/A"),
                "Industry": info.get("industry", "N/A")
            }
        except:
            pass
    
    comps = pd.DataFrame.from_dict(data, orient="index")
    comps["EV/Revenue"] = None   # yfinance doesn't give reliable revenue
    comps["EV/EBITDA"]  = None
    return comps

# ─── Example usage ───
if __name__ == "__main__":
    comps = build_comps_table(
        sector="Technology",
        industry="Software - Application",
        country="India",                # change to "United States" etc.
        market_cap_category="Mid Cap",
        fmp_api_key="YOUR_KEY_HERE"
    )
    
    print("\nComps Table:\n")
    print(comps)
    
    # Save to CSV for agent use
    comps.to_csv("comps_table.csv")
