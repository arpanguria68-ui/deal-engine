PythonCopyimport numpy as np
import matplotlib.pyplot as plt
from matplotlib.backends.backend_pdf import PdfPages
import pandas as pd
from scipy.optimize import minimize

# ────────────────────────────────────────────────
# 1. Exact OU path simulation
# ────────────────────────────────────────────────
def ou_path_exact(X0, theta, kappa, sigma, T, n_steps=252, n_paths=1):
    dt = T / n_steps
    t = np.linspace(0, T, n_steps + 1)
    paths = np.zeros((n_paths, n_steps + 1))
    paths[:, 0] = X0
    for i in range(1, n_steps + 1):
        exp_term = np.exp(-kappa * dt)
        mean = theta + (paths[:, i-1] - theta) * exp_term
        var = (sigma**2 / (2 * kappa)) * (1 - np.exp(-2 * kappa * dt))
        paths[:, i] = np.random.normal(mean, np.sqrt(var))
    return t, paths

# ────────────────────────────────────────────────
# 2. MLE calibration (exact conditional likelihood)
# ────────────────────────────────────────────────
def ou_log_likelihood_neg(params, x, dt=1.0):
    kappa, theta, sigma = params
    if kappa <= 1e-8 or sigma <= 1e-8:
        return 1e12
    a = np.exp(-kappa * dt)
    b = theta * (1 - a)
    c2 = (sigma**2 / (2 * kappa)) * (1 - a**2)
    if c2 <= 0:
        return 1e12
    residuals = x[1:] - (b + a * x[:-1])
    ll = -0.5 * len(residuals) * np.log(2 * np.pi * c2) - 0.5 * np.sum(residuals**2 / c2)
    return -ll

def calibrate_ou_mle(x, dt=1.0):
    x = np.asarray(x)
    if len(x) < 10:
        return None  # too few points
    
    # OLS initial guess
    dx = np.diff(x)
    x_lag = x[:-1]
    slope, intercept = np.polyfit(x_lag, dx, 1)
    kappa_ols = max(0.01, -slope / dt)
    theta_ols = intercept / slope if slope != 0 else np.mean(x)
    sigma_ols = np.std(dx - (intercept + slope * x_lag)) / np.sqrt(dt)
    initial = [kappa_ols, theta_ols, sigma_ols]
    
    bounds = [(1e-5, 20), (min(x)*0.5, max(x)*1.5), (1e-5, 5*np.std(dx))]
    
    res = minimize(
        ou_log_likelihood_neg, x0=initial, args=(x, dt),
        method='L-BFGS-B', bounds=bounds, options={'disp': False}
    )
    
    if not res.success:
        print("MLE did not converge well for one series")
        return None
    
    kappa, theta, sigma = res.x
    return {'kappa': kappa, 'theta': theta, 'sigma': sigma}

# ────────────────────────────────────────────────
# 3. Main function – per-deal plots + PDF report
# ────────────────────────────────────────────────
def generate_ou_synergy_report(
    real_data_list: list[dict],           # each: {'deal_id': str, 'time': [...], 'synergy': [...], 'error': [...] (optional)}
    T=5.0,
    n_steps=252,
    n_paths=60,
    use_percentage=False,
    target_synergy=15.0,
    pdf_filename="ou_synergy_report.pdf",
    figsize_per_page=(14, 10)
):
    pdf = PdfPages(pdf_filename)
    
    for deal_idx, data in enumerate(real_data_list):
        deal_id = data.get('deal_id', f'Deal {deal_idx+1}')
        t_real = np.array(data['time'])
        y_real = np.array(data['synergy'])
        err_real = np.array(data.get('error', [0]*len(t_real)))  # uncertainty ±
        
        if use_percentage and target_synergy > 0:
            y_real = y_real / target_synergy * 100
            err_real = err_real / target_synergy * 100
        
        # Fit OU parameters using MLE
        fitted = calibrate_ou_mle(y_real, dt=1.0)  # assume annual data
        
        fig, (ax1, ax2) = plt.subplots(2, 1, figsize=figsize_per_page,
                                       gridspec_kw={'height_ratios': [3, 1]})
        
        # Plot real data with error bars
        ax1.errorbar(t_real, y_real, yerr=err_real, fmt='o', color='black', 
                     ecolor='gray', capsize=5, capthick=1.5, elinewidth=1.5,
                     markersize=9, zorder=10, label=f'{deal_id} (observed ± error)')
        
        # Plot fitted OU path if calibration succeeded
        if fitted:
            t_fit, paths_fit = ou_path_exact(
                X0=y_real[0],
