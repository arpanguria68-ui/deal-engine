# NEW: Debt Schedule Parameters
debt_pct_ev           = {'min': 0.35, 'mode': 0.50, 'max': 0.65}  # leverage % of EV
interest_spread       = {'mean': 0.045, 'std': 0.008}            # over SOFR (base 5.3% → total 9.8%)
amort_rate            = 0.05                                    # 5% annual principal paydown (fixed)
prepay_pct            = {'alpha': 2, 'beta': 2, 'max': 0.50}     # excess CF prepay % (skewed)
tax_rate              = 0.25                                    # for interest tax shield
fcf_margin            = 0.70                                    # FCF as % of EBITDA (pre-debt)

n_simulations = 10000

# ────────────────────────────────────────────────
# Main Monte Carlo loop (with debt randomization)
# ────────────────────────────────────────────────
irrs = np.zeros(n_simulations)
equity_cf_to_date = np.zeros(n_simulations)  # Track equity cash out (for IRR calc)

for i in range(n_simulations):
    # ─── EBITDA / Exit draws (same as before) ───
    growth_rates = np.random.normal(ebitda_growth['mean'], ebitda_growth['std'], holding_period_years)
    margin_changes = np.random.triangular(margin_expansion['min'], margin_expansion['mode'], margin_expansion['max'], holding_period_years)
    synergy_pct = np.random.beta(synergy_capture_pct['alpha'], synergy_capture_pct['beta']) * synergy_capture_pct['max']
    exit_mult = np.random.normal(exit_multiple['mean'], exit_multiple['std'])
    exit_mult = max(6.0, exit_mult)  # floor
    opex_overrun = np.random.normal(opex_overrun_pct['mean'], opex_overrun_pct['std'], holding_period_years)
    
    # Project EBITDA path
    ebitda = [entry_ebitda]
    for yr in range(holding_period_years):
        new_ebitda = ebitda[-1] * (1 + growth_rates[yr])
        new_ebitda *= (1 + margin_changes[yr])
        new_ebitda *= (1 - opex_overrun[yr])
        ebitda.append(new_ebitda)
    
    # ─── NEW: Debt Schedule Randomization ───
    # Initial EV and Debt
    ev = entry_ebitda * entry_multiple
    debt_pct = np.random.triangular(debt_pct_ev['min'], debt_pct_ev['mode'], debt_pct_ev['max'])
    initial_debt = ev * debt_pct
    
    # Interest rate
    base_rate = 0.053  # SOFR proxy
    spread = np.random.normal(interest_spread['mean'], interest_spread['std'])
    interest_rate = base_rate + spread
    
    # Prepay %
    prepay_pct_actual = np.random.beta(prepay_pct['alpha'], prepay_pct['beta']) * prepay_pct['max']
    
    # Debt schedule (principal + interest)
    debt_balance = initial_debt
    equity_cash_flows = []  # Cash to equity holders each year
    
    for yr in range(holding_period_years):
        # EBITDA for year
        current_ebitda = ebitda[yr + 1]
        
        # Interest expense
        interest = debt_balance * interest_rate
        tax_shield = interest * tax_rate
        after_tax_interest = interest * (1 - tax_rate)
        
        # Pre-debt FCF
        pre_debt_fcf = current_ebitda * fcf_margin
        
        # Debt service
        principal_amort = debt_balance * amort_rate
        excess_cf = max(0, pre_debt_fcf - after_tax_interest - principal_amort)
        prepay = excess_cf * prepay_pct_actual
        total_principal_pay = principal_amort + prepay
        
        # Update debt balance
        debt_balance = max(0, debt_balance - total_principal_pay)
        
        # Equity FCF (after all debt service)
        equity_fcf = pre_debt_fcf - after_tax_interest - total_principal_pay + tax_shield
        equity_cash_flows.append(equity_fcf)
    
    # Exit: Terminal value to equity (after debt repayment)
    terminal_ev = ebitda[-1] * exit_mult
    terminal_equity_value = max(0, terminal_ev - debt_balance)  # Pay off remaining debt
    equity_cash_flows[-1] += terminal_equity_value  # Add to final year
    
    # Full equity cash flows: initial equity outlay + annual FCF + exit
    initial_equity = ev - initial_debt
    full_equity_cf = [-initial_equity] + equity_cash_flows
    
    # Calculate IRR on equity cash flows
    def npv_equity(r):
        return sum(cf / (1 + r)**t for t, cf in enumerate(full_equity_cf))
    
    try:
        irr = optimize.newton(npv_equity, 0.15)
    except RuntimeError:
        irr = np.nan
    
    irrs[i] = irr
    equity_cf_to_date[i] = initial_equity  # Track for summary stats

# ────────────────────────────────────────────────
# Results & Visualization (enhanced for debt)
