    context=[task_fin]  # Parallel chain
)

# Step 3: Conditional/Sequential Task 3 - Risk Assessment (chains from parallel)
task_risk = Task(
    description=(
        "Incorporate tech/ESG outputs + market shares. Run cyber scan and antitrust HHI. "
        "If HHI >2500 or cyber vulns >2, flag high risk and escalate. Output: Risk heatmap JSON."
    ),
    agent=risk_agent,
    expected_output="JSON: vulns, HHI, overall risk level (low/medium/high), escalation flag.",
    context=[task_tech, task_esg]  # Chains from both parallels
)

