PythonCopyimport numpy as np
from scipy.stats import norm
from scipy.integrate import solve_ivp
from config import config

class SimulationEngine:
    def ou_synergies(self, syn_target, kappa=0.5, theta=0.6*syn_target, sigma=0.1, T=5, dt=0.25):
        """OU paths for synergy fade."""
        n_paths = config.N_SIM
        paths = np.zeros((n_paths, int(T/dt) + 1))
        paths[:, 0] = syn_target
        for t in range(1, paths.shape[1]):
            dw = np.random.normal(0, np.sqrt(dt), n_paths)
            paths[:, t] = paths[:, t-1] + kappa * (theta - paths[:, t-1]) * dt + sigma * dw
        return paths
    
    def hull_white_rates(self, a=0.05, sigma=0.01, r0=0.05, T=5, dt=0.25, theta_func=None):
        """Hull-White paths (simple Euler)."""
        if theta_func is None:
            theta_func = lambda t: 0.05  # Constant mock
        n_paths = config.N_SIM
        paths = np.zeros((n_paths, int(T/dt) + 1))
        paths[:, 0] = r0
        for t in range(1, paths.shape[1]):
            theta_t = theta_func((t-1)*dt)
            dw = np.random.normal(0, np.sqrt(dt), n_paths)
            paths[:, t] = paths[:, t-1] + (theta_t - a * paths[:, t-1]) * dt + sigma * dw
        return paths
    
    def run_irr_monte_carlo(self, params):
        """Full IRR sim integrating OU + Hull-White."""
        syn_paths = self.ou_synergies(params['syn_target'])
        rate_paths = self.hull_white_rates()
        irr_list = []
        np.random.seed(config.SEED)
        for i in range(config.N_SIM):
            # Mock FCF with synergies
            fcf = params['entry_ebitda'] * syn_paths[i, 1:]  # Years 1-5
            # Discount with path avg rate
            avg_rate = np.mean(rate_paths[i])
            npv = sum(f / (1 + avg_rate)**t for t, f in enumerate(fcf, 1))
            # IRR approx (simplified)
            def npv_irr(r): return npv - params['price'] / (1 + r)**0 + sum(f / (1 + r)**t for t, f in enumerate(fcf, 1))
            irr = 0.1  # Placeholder; use newton for real
            irr_list.append(irr)
        return {'mean_irr': np.mean(irr_list), 'p_ge_18': np.mean(np.array(irr_list) >= 0.18)}
