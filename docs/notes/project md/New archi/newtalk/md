PythonCopydef ou_path_exact(X0, theta, kappa, sigma, T, n_steps=252):
    dt = T / n_steps
    path = np.zeros(n_steps + 1)
    path[0] = X0
    for i in range(1, n_steps + 1):
        exp_term = np.exp(-kappa * dt)
        mean = theta + (path[i-1] - theta) * exp_term
        var = (sigma**2 / (2 * kappa)) * (1 - np.exp(-2 * kappa * dt))
        path[i] = np.random.normal(mean, np.sqrt(var))
    return path

