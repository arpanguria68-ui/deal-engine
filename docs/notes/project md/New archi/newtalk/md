PythonCopyimport sqlite3
from ragas import evaluate
from ragas.metrics import faithfulness
from config import config

class GovernanceWrapper:
    def __init__(self):
        self.conn = sqlite3.connect(config.CACHE_DB)
        self._create_audit_table()
    
    def _create_audit_table(self):
        self.conn.execute("""
            CREATE TABLE IF NOT EXISTS audits (
                id INTEGER PRIMARY KEY,
                query TEXT,
                agent TEXT,
                output TEXT,
                faithfulness FLOAT,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        """)
        self.conn.commit()
    
    def evaluate_faithfulness(self, query, output, contexts):
        """RAGAS eval."""
        dataset = [{"question": query, "answer": output, "contexts": contexts}]
        result = evaluate(dataset, metrics=[faithfulness])
        score = result['faithfulness'].iloc[0]
        return score
    
    def log_run(self, query, agent, output, contexts):
        score = self.evaluate_faithfulness(query, output, contexts)
        self.conn.execute("INSERT INTO audits (query, agent, output, faithfulness) VALUES (?, ?, ?, ?)",
                          (query, agent, output, score))
        self.conn.commit()
        return score > config.FAITHFULNESS_THRESHOLD
    
    def escalate_if_needed(self, score, risk_level="medium"):
        if score < config.FAITHFULNESS_THRESHOLD or risk_level == "high":
            return True  # Flag for human
        return False
