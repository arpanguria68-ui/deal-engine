def normalize_ebitda(inputs):
    path, year = inputs.split(',')
    df = pd.read_excel(path, sheet_name='P&L')
    ebitda = df[df['Year'] == int(year)]['EBITDA'].iloc[0]
    add_backs = df[df['Category'].str.contains('one-off', na=False)]['Amount'].sum()
    return {'adjusted': ebitda + add_backs, 'bridge': add_backs}

