    words1 = set(section1_text.lower().split())
    words2 = set(section2_text.lower().split())
    added = words2 - words1
    removed = words1 - words2
    
    return {
        'similarity': similarity,
        'change_flag': change_flag,
        'added_keywords': list(added)[:10],
        'removed_keywords': list(removed)[:10]
    }

