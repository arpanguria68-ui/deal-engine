Region Detection Helper (add to run_due_diligence):
Pythondef detect_region(ticker: str) -> str:
    if ticker.endswith(('.NS', '.BO')): return "India"
    if ticker.endswith(('.DE', '.PA', '.L')): return "EU"
    return "US"  # default

# Then inside run_due_diligence:
region = detect_region(ticker)
thresholds = self.get_thresholds(region)
