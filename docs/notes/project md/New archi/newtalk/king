}

def get_thresholds(self, region: str = "US"):
    return self.thresholds.get(region, self.thresholds["US"])

# Usage in compare_filings
thresholds = self.get_thresholds(region="India")  # or detect from ticker suffix (.NS, .DE, etc.)
