from sklearn.cluster import DBSCAN
from datetime import datetime, timedelta

def cluster_8k_events(self, filings_8k: list[dict], max_days_gap: int = 45) -> list[dict]:
    """
    Cluster 8-K filings that are likely related (e.g., earnings + M&A + exec change within 45 days).
    Uses simple temporal clustering + keyword overlap.
    """
    if not filings_8k:
        return []
    
    # Convert to DataFrame with datetime
    df = pd.DataFrame(filings_8k)
    df['filed_at'] = pd.to_datetime(df['filed_at'])
    df = df.sort_values('filed_at').reset_index(drop=True)
    
    # Extract simple event type keywords
    def get_event_type(text: str) -> str:
        text_lower = text.lower()
        if any(w in text_lower for w in ['earnings', 'results', 'financial', 'revenue']):
            return 'Earnings'
        if any(w in text_lower for w in ['merger', 'acquisition', 'agreement', 'transaction']):
            return 'M&A'
        if any(w in text_lower for w in ['director', 'officer', 'executive', 'resignation', 'appointment']):
            return 'Exec Change'
        return 'Other'
    
    df['event_type'] = df['mda'].apply(get_event_type)  # using mda field for 8-K
    
    # Temporal clustering (DBSCAN on timestamps)
    times = df['filed_at'].values.astype('datetime64[D]').astype(int).reshape(-1, 1)
    clustering = DBSCAN(eps=max_days_gap, min_samples=1, metric='manhattan').fit(times)
    df['cluster_id'] = clustering.labels_
    
    # Group by cluster
    clusters = []
    for cluster_id, group in df.groupby('cluster_id'):
        if len(group) == 1:
            continue  # skip singletons unless you want them
        
        cluster_start = group['filed_at'].min()
        cluster_end = group['filed_at'].max()
        types = group['event_type'].unique().tolist()
        filing_count = len(group)
        
        clusters.append({
            'cluster_id': int(cluster_id),
            'start_date': cluster_start.strftime('%Y-%m-%d'),
            'end_date': cluster_end.strftime('%Y-%m-%d'),
            'duration_days': (cluster_end - cluster_start).days,
            'event_types': types,
            'filing_count': filing_count,
            'high_risk': 'M&A' in types and 'Earnings' in types,  # example rule
            'filings': group[['filing_id', 'filed_at', 'event_type']].to_dict('records')
        })
    
    return sorted(clusters, key=lambda x: x['start_date'], reverse=True)
