# DealForge AI Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dealforge
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production

# OpenAI / Codex
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
CODEX_MODEL=gpt-5.1-codex-max

# Mistral
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-pro

# NVIDIA
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm5

# PageIndex (VectifyAI)
PAGEINDEX_API_KEY=...
PAGEINDEX_BASE_URL=https://api.vectify.ai/v1

# Agent Settings
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300

# Deal Scoring
DEAL_SCORING_THRESHOLD=0.65
